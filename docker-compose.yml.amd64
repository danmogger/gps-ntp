version: '4'
services:
  gps-ntp:
    container_name: gps-ntp
    image: dduncandocker/gps-ntp:1.2amd64
    cap_add:
      - SYS_TIME
    build: .
    ports:
      - "123:123/udp"
    environment:
      - USER_ID=1001
      - GROUP_ID=1001
      - DEVICE=/dev/ttyACM0
      - TZ=America/Denver
    devices:
      - "/dev/ttyACM0:/dev/ttyACM0"
    privileged: true
    restart: unless-stopped
